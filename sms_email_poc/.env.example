# Copy to .env and fill values
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_ACCOUNT_SID=your_twilio_account_sid
SENDGRID_API_KEY=your_sendgrid_api_key
REPLY_EMAIL=you@example.com
# Optional SMTP settings if you want to send email replies directly
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=supersecret
TWILIO_PHONE_NUMBER=+15552223333
# Short shared secret for local admin API calls (set before enabling `/send_sms`)
ADMIN_TOKEN=change-me-to-a-secret
# Telegram bot token for webhook replies
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# Optional secret token to validate Telegram webhook requests
TELEGRAM_WEBHOOK_SECRET=change-to-a-long-random-string
