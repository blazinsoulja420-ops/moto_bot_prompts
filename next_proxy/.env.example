# Server-only secrets (do NOT commit real .env.local to git)
ADMIN_TOKEN=replace_with_secure_value

# Upstream Suno API URL your proxy will call. Example: https://api.suno.ai/v1/generate
SUNO_API_URL=

# Prefer API key; fallback to cookie if required by vendor
SUNO_API_KEY=
SUNO_COOKIE=

# Optional defaults
SUNO_DEFAULT_MODEL=musicgen
SUNO_DEFAULT_VOICE=default

# Optional: S3 configuration (if you decide to store audio files)
# S3_BUCKET=your-bucket
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
